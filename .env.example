# ═══════════════════════════════════════════════════════════════
#  .env.example  —  Copy this file to ".env" and fill in your keys
#  NEVER share your .env file or commit it to git!
# ═══════════════════════════════════════════════════════════════

# ── HYPERLIQUID ─────────────────────────────────────────────────
# Your EVM wallet private key (starts with 0x)
# Get this from your wallet (MetaMask → Account Details → Export Private Key)
HL_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Your wallet address (starts with 0x)
HL_ACCOUNT_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE

# ── LIGHTER (zkSync DEX) ────────────────────────────────────────
# Can use the same private key as Hyperliquid if same wallet
LIGHTER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Arbitrum mainnet RPC URL (Lighter runs on Arbitrum)
LIGHTER_WEB3_URL=https://arb1.arbitrum.io/rpc

# ── OPTIONAL: ANTHROPIC VISION API (chart reading) ─────────────
# Get your key at https://console.anthropic.com
# Only needed if use_chart_confirmation = True in config.py
ANTHROPIC_API_KEY=

# ── OPTIONAL: TELEGRAM ALERTS ──────────────────────────────────
# Create a bot via @BotFather on Telegram, get the token
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID (send /start to @userinfobot to get it)
TELEGRAM_CHAT_ID=

# ── CLOUD / RAILWAY ─────────────────────────────────────────────
# Mount a Railway Volume at /data and set this so all state files
# (checkpoints.db, trade_memory.json, trades_log.csv, state.json)
# survive restarts and redeploys.
DATA_DIR=/data

# Full URL of your Netlify dashboard (no trailing slash)
# e.g. https://your-agent-dashboard.netlify.app
DASHBOARD_URL=

# Secret token the agent sends in X-Token header when pushing state.
# Must match DASHBOARD_TOKEN in your Netlify environment variables.
DASHBOARD_TOKEN=
